<h1>Hospital Management System</h1>

<div class="row">

    <div class="col-md-4">
        <div class="card p-3">
            <h3>Patients</h3>
            <p>Manage patient records</p>
            <a asp-controller="Patients" asp-action="Index" class="btn btn-primary">View Patients</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <h3>Doctors</h3>
            <p>Manage doctor information</p>
            <a asp-controller="Doctors" asp-action="Index" class="btn btn-success">View Doctors</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3">
            <h3>Appointments</h3>
            <p>Schedule appointments</p>
            <a asp-controller="Appointments" asp-action="Index" class="btn btn-warning">View Appointments</a>
        </div>
    </div>

</div>